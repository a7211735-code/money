<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<link rel="icon" type="image/png" href="data:image/png;base64,">
<link rel="apple-touch-icon" href="data:image/png;base64,">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-title" content="ADS 淨利計算表（高）">
<meta name="application-name" content="ADS 淨利計算表（高）">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ADS 淨利計算表（高）</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Syne:wght@400;600;800&display=swap" rel="stylesheet">
<style>
  :root {
    --bg:#0e0e10;--surface:#18181c;--surface2:#222228;
    --border:rgba(255,255,255,0.07);
    --accent:#b8f548;--accent-dim:rgba(184,245,72,0.1);
    --red:#ff5c5c;--red-dim:rgba(255,92,92,0.12);
    --blue:#4da6ff;--blue-dim:rgba(77,166,255,0.1);
    --amber:#ffc850;--amber-dim:rgba(255,200,80,0.1);
    --text:#f0f0f0;--muted:#666;
    --mono:'DM Mono',monospace;--display:'Syne',sans-serif;
  }
  *{margin:0;padding:0;box-sizing:border-box;}
  body{background:var(--bg);color:var(--text);font-family:var(--mono);min-height:100vh;padding:2rem 1rem 4rem;}
  body::before{content:'';position:fixed;inset:0;
    background-image:linear-gradient(rgba(255,255,255,0.015)1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.015)1px,transparent 1px);
    background-size:40px 40px;pointer-events:none;z-index:0;}
  .container{max-width:1140px;margin:0 auto;position:relative;z-index:1;}

  /* Header */
  header{display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:1.75rem;padding-bottom:1.25rem;border-bottom:1px solid var(--border);}
  .logo{font-family:var(--display);font-weight:800;font-size:1.8rem;letter-spacing:-0.03em;}
  .logo span{color:var(--accent);}
  .tagline{font-size:0.62rem;color:var(--muted);letter-spacing:0.12em;text-transform:uppercase;}

  /* Tabs */
  .tabs{display:flex;gap:2px;margin-bottom:1.5rem;background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:4px;width:fit-content;}
  .tab{background:none;border:none;color:var(--muted);font-family:var(--mono);font-size:0.75rem;letter-spacing:0.06em;padding:7px 18px;border-radius:7px;cursor:pointer;transition:all 0.2s;}
  .tab.active{background:var(--surface2);color:var(--text);}
  .tab:hover:not(.active){color:var(--text);}
  .panel{display:none;}.panel.active{display:block;}

  /* Month bar */
  .month-bar{display:flex;align-items:center;gap:10px;margin-bottom:1.5rem;flex-wrap:wrap;}
  .month-bar label{font-size:0.62rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);}
  .month-bar input[type=month]{background:var(--surface2);border:1px solid transparent;border-radius:7px;color:var(--text);font-family:var(--mono);font-size:0.8rem;padding:7px 12px;outline:none;transition:border-color 0.2s;}
  .month-bar input[type=month]:focus{border-color:var(--accent);}
  .month-label{font-family:var(--display);font-size:1rem;font-weight:600;color:var(--accent);}

  /* Metrics */
  .metrics{display:grid;gap:1px;background:var(--border);border-radius:12px;overflow:hidden;margin-bottom:1.5rem;}
  .metrics.c3{grid-template-columns:repeat(3,1fr);}
  .metrics.c4{grid-template-columns:repeat(4,1fr);}
  .metrics.c5{grid-template-columns:repeat(5,1fr);}
  .metric{background:var(--surface);padding:1.1rem 1.25rem;position:relative;overflow:hidden;}
  .metric::after{content:attr(data-i);position:absolute;top:-10px;right:8px;font-family:var(--display);font-size:3.5rem;font-weight:800;color:rgba(255,255,255,0.025);pointer-events:none;}
  .metric-label{font-size:0.58rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--muted);margin-bottom:0.35rem;}
  .metric-value{font-family:var(--display);font-size:1.5rem;font-weight:600;line-height:1;color:var(--accent);}
  .metric-value.n{color:var(--text);}.metric-value.b{color:var(--blue);}.metric-value.a{color:var(--amber);}.metric-value.r{color:var(--red);}

  /* Card */
  .card{background:var(--surface);border:1px solid var(--border);border-radius:12px;overflow:hidden;margin-bottom:1.25rem;}
  .card-header{padding:0.85rem 1.25rem;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;}
  .card-title{font-size:0.6rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--muted);}

  /* Form */
  .form-body{padding:1.25rem;display:grid;gap:10px;}
  .form-body.c4{grid-template-columns:repeat(4,1fr);}
  .form-body.c3{grid-template-columns:repeat(3,1fr);}
  .field{display:flex;flex-direction:column;gap:5px;}
  .field.s2{grid-column:span 2;}.field.s3{grid-column:span 3;}.field.s4{grid-column:span 4;}
  .field label{font-size:0.58rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);}
  .field input,.field select{background:var(--surface2);border:1px solid transparent;border-radius:7px;color:var(--text);font-family:var(--mono);font-size:0.8rem;padding:8px 10px;outline:none;transition:border-color 0.2s;width:100%;}
  .field input::placeholder{color:rgba(255,255,255,0.15);}
  .field input:focus,.field select:focus{border-color:var(--accent);}
  .field select option{background:#222228;}
  .field input[readonly]{opacity:0.55;cursor:not-allowed;}

  .form-footer{padding:0 1.25rem 1.25rem;display:flex;gap:8px;justify-content:flex-end;align-items:center;}
  .calc-preview{flex:1;font-size:0.72rem;color:var(--muted);background:var(--surface2);border-radius:7px;padding:7px 12px;line-height:1.6;}
  .calc-preview strong{color:var(--accent);}.calc-preview.neg strong{color:var(--red);}

  /* Buttons */
  .btn-p{background:var(--accent);color:#0e0e10;border:none;border-radius:7px;padding:8px 20px;font-family:var(--mono);font-size:0.8rem;font-weight:500;cursor:pointer;transition:opacity 0.2s;white-space:nowrap;}
  .btn-p:hover{opacity:0.85;}
  .btn-s{background:none;color:var(--muted);border:1px solid var(--border);border-radius:7px;padding:8px 16px;font-family:var(--mono);font-size:0.8rem;cursor:pointer;transition:all 0.2s;white-space:nowrap;}
  .btn-s:hover{color:var(--text);border-color:rgba(255,255,255,0.2);}
  .btn-icon{background:none;border:none;cursor:pointer;font-size:12px;padding:3px 7px;border-radius:5px;transition:all 0.2s;color:rgba(255,255,255,0.18);}
  .btn-icon:hover{color:var(--red);background:var(--red-dim);}
  .btn-sm{background:none;border:1px solid var(--border);border-radius:6px;color:var(--muted);font-family:var(--mono);font-size:0.7rem;padding:4px 10px;cursor:pointer;transition:all 0.2s;}
  .btn-sm:hover{color:var(--accent);border-color:var(--accent);background:var(--accent-dim);}
  .btn-sm.danger:hover{color:var(--red);border-color:var(--red);background:var(--red-dim);}

  /* Filter */
  .filter-wrap{display:flex;gap:8px;align-items:center;flex-wrap:wrap;}
  .filter-wrap input,.filter-wrap select{background:var(--surface2);border:1px solid transparent;border-radius:6px;color:var(--text);font-family:var(--mono);font-size:0.72rem;padding:5px 9px;outline:none;transition:border-color 0.2s;}
  .filter-wrap input:focus,.filter-wrap select:focus{border-color:var(--accent);}
  .filter-wrap input::placeholder{color:rgba(255,255,255,0.2);}

  /* Table */
  .table-wrap{overflow-x:auto;}
  table{width:100%;border-collapse:collapse;font-size:0.76rem;}
  thead th{padding:0.6rem 0.85rem;text-align:left;font-size:0.54rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);border-bottom:1px solid var(--border);white-space:nowrap;font-weight:400;}
  thead th.r{text-align:right;}
  tbody tr{border-bottom:1px solid var(--border);transition:background 0.15s;}
  tbody tr:last-child{border-bottom:none;}
  tbody tr:hover{background:rgba(255,255,255,0.02);}
  tbody td{padding:0.65rem 0.85rem;color:var(--text);white-space:nowrap;}
  tbody td.r{text-align:right;}tbody td.m{color:var(--muted);font-size:0.72rem;}
  .vp{color:var(--accent);font-weight:500;}.vn{color:var(--red);font-weight:500;}

  .badge{display:inline-block;padding:2px 9px;border-radius:99px;font-size:0.63rem;}
  .ch-online{background:rgba(77,166,255,0.12);color:#4da6ff;}
  .ch-store{background:rgba(184,245,72,0.12);color:#b8f548;}
  .ch-partner{background:rgba(255,200,80,0.12);color:#ffc850;}
  .ch-other{background:rgba(150,150,150,0.12);color:#aaa;}
  .level-badge{display:inline-block;padding:2px 8px;border-radius:5px;font-size:0.63rem;}
  .lv-0{background:rgba(150,150,150,0.12);color:#aaa;}
  .lv-1{background:rgba(77,166,255,0.12);color:#4da6ff;}
  .lv-2{background:rgba(184,245,72,0.12);color:#b8f548;}
  .lv-3{background:rgba(255,200,80,0.12);color:#ffc850;}

  .empty-state{padding:3rem;text-align:center;color:var(--muted);font-size:0.78rem;line-height:2.2;}

  /* ── Product picker ── */
  .product-picker-wrap{padding:0 1.25rem 0;}
  .picker-label{font-size:0.58rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);margin-bottom:8px;}

  .picker-header{display:flex;align-items:center;gap:8px;margin-bottom:8px;flex-wrap:wrap;}
  .picker-search{background:var(--surface2);border:1px solid transparent;border-radius:6px;color:var(--text);font-family:var(--mono);font-size:0.75rem;padding:6px 10px;outline:none;transition:border-color 0.2s;width:200px;}
  .picker-search:focus{border-color:var(--accent);}
  .picker-search::placeholder{color:rgba(255,255,255,0.2);}

  .product-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(155px,1fr));gap:6px;max-height:240px;overflow-y:auto;padding:2px 0 12px;}
  .product-grid::-webkit-scrollbar{width:4px;}
  .product-grid::-webkit-scrollbar-track{background:transparent;}
  .product-grid::-webkit-scrollbar-thumb{background:rgba(255,255,255,0.1);border-radius:2px;}

  .prod-chip{display:flex;flex-direction:column;gap:3px;padding:8px 10px;border-radius:8px;border:1px solid var(--border);cursor:pointer;transition:all 0.15s;background:var(--surface2);user-select:none;}
  .prod-chip:hover{border-color:rgba(255,255,255,0.2);}
  .prod-chip.selected{border-color:var(--accent);background:var(--accent-dim);}
  .prod-chip.selected .chip-name{color:var(--accent);}
  .chip-name{font-size:0.75rem;color:var(--text);line-height:1.2;}
  .chip-cost{font-size:0.65rem;color:var(--muted);}
  .chip-stock{font-size:0.62rem;}
  .chip-stock.ok{color:var(--accent);opacity:0.7;}
  .chip-stock.low{color:var(--amber);}
  .chip-stock.neg{color:var(--red);}

  /* Selected items list */
  .selected-items{padding:0 1.25rem;margin-bottom:10px;}
  .selected-items-label{font-size:0.58rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);margin-bottom:8px;}
  .item-rows{display:flex;flex-direction:column;gap:6px;}

  .item-row-entry{display:grid;grid-template-columns:1fr 80px 110px 110px 28px;gap:6px;align-items:center;background:var(--surface2);border-radius:7px;padding:7px 10px;}
  .item-row-entry .iname{font-size:0.75rem;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
  .item-row-entry input{background:var(--surface);border:1px solid transparent;border-radius:5px;color:var(--text);font-family:var(--mono);font-size:0.75rem;padding:4px 7px;outline:none;transition:border-color 0.2s;width:100%;text-align:right;}
  .item-row-entry input:focus{border-color:var(--accent);}
  .item-row-entry input[readonly]{opacity:0.5;cursor:not-allowed;}
  .item-row-entry .ilabel{font-size:0.58rem;color:var(--muted);text-align:center;}

  .no-items{font-size:0.72rem;color:var(--muted);padding:8px 0;}

  /* Inv adjust */
  .inv-actions{display:flex;gap:4px;align-items:center;}
  .adj-input{width:54px;background:var(--surface2);border:1px solid transparent;border-radius:5px;color:var(--text);font-family:var(--mono);font-size:0.73rem;padding:4px 6px;outline:none;text-align:center;transition:border-color 0.2s;}
  .adj-input:focus{border-color:var(--accent);}
  .btn-adj{background:none;border:1px solid var(--border);border-radius:5px;color:var(--muted);font-family:var(--mono);font-size:0.65rem;padding:4px 7px;cursor:pointer;transition:all 0.2s;white-space:nowrap;}
  .btn-adj.pl:hover{color:var(--accent);border-color:var(--accent);background:var(--accent-dim);}
  .btn-adj.mi:hover{color:var(--red);border-color:var(--red);background:var(--red-dim);}
  .sk-ok{color:var(--accent);font-weight:600;}.sk-low{color:var(--amber);font-weight:600;}.sk-neg{color:var(--red);font-weight:600;}

  /* Modal */
  .modal-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.65);z-index:100;align-items:center;justify-content:center;}
  .modal-bg.open{display:flex;}
  .modal{background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:1.5rem;width:340px;max-width:92vw;}
  .modal h3{font-family:var(--display);font-size:1rem;font-weight:600;margin-bottom:0.5rem;}
  .modal p{font-size:0.78rem;color:var(--muted);margin-bottom:1.25rem;line-height:1.7;}
  .modal-btns{display:flex;gap:8px;justify-content:flex-end;}

  /* Products tag list in table */
  .prod-tags{display:flex;flex-wrap:wrap;gap:3px;max-width:220px;}
  .prod-tag{display:inline-block;background:var(--surface2);color:var(--muted);padding:1px 7px;border-radius:4px;font-size:0.65rem;white-space:nowrap;}

  @media(max-width:700px){
    .form-body.c4{grid-template-columns:1fr 1fr;}
    .field.s3,.field.s4{grid-column:span 2;}
    .metrics.c5{grid-template-columns:1fr 1fr;}
    .metrics.c4{grid-template-columns:1fr 1fr;}
    .metric-value{font-size:1.15rem;}
    .item-row-entry{grid-template-columns:1fr 70px 90px 90px 28px;}
    .product-grid{grid-template-columns:repeat(auto-fill,minmax(130px,1fr));}
  }
</style>
</head>
<body>
<div class="container">

<header>
  <div style="display:flex;align-items:center;gap:14px;">
    <img src="data:image/png;base64," alt="ADS Logo" style="width:52px;height:52px;border-radius:10px;object-fit:cover;flex-shrink:0;">
    <div>
      <div class="logo">ADS <span>淨利計算表（高）</span></div>
      <div class="tagline">Sales Profit Tracker</div>
    </div>
  </div>
  <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
    <button class="btn-s" onclick="exportSalesCSV()" style="font-size:0.7rem;padding:6px 12px;">⬇ 銷售紀錄 CSV</button>
    <button class="btn-s" onclick="exportInvCSV()" style="font-size:0.7rem;padding:6px 12px;">⬇ 庫存 CSV</button>
    <button class="btn-s" onclick="exportMonthCSV()" style="font-size:0.7rem;padding:6px 12px;">⬇ 本月報表 CSV</button>
  </div>
</header>

<div class="tabs">
  <button class="tab active" onclick="switchTab('sales',this)">銷售紀錄</button>
  <button class="tab" onclick="switchTab('inventory',this)">產品庫存</button>
</div>

<!-- ══════════ SALES ══════════ -->
<div id="panel-sales" class="panel active">

  <div class="month-bar">
    <label>查看月份</label>
    <input type="month" id="view-month" onchange="onMonthChange()">
    <span class="month-label" id="month-display"></span>
  </div>

  <div class="metrics c5">
    <div class="metric" data-i="01"><div class="metric-label">本月售出金額</div><div class="metric-value b" id="m-rev">$0</div></div>
    <div class="metric" data-i="02"><div class="metric-label">本月總成本</div><div class="metric-value a" id="m-cost">$0</div></div>
    <div class="metric" data-i="03"><div class="metric-label">本月手續費/運費</div><div class="metric-value r" id="m-fee">$0</div></div>
    <div class="metric" data-i="04"><div class="metric-label">本月淨獲利</div><div class="metric-value" id="m-profit">$0</div></div>
    <div class="metric" data-i="05"><div class="metric-label">本月筆數</div><div class="metric-value n" id="m-count">0</div></div>
  </div>

  <!-- Add form -->
  <div class="card">
    <div class="card-header"><span class="card-title">新增銷售紀錄</span></div>

    <!-- Basic info -->
    <div class="form-body c4">
      <div class="field">
        <label>日期</label>
        <input type="date" id="f-date">
      </div>
      <div class="field s2">
        <label>客人姓名 / 帳號</label>
        <input type="text" id="f-customer" placeholder="例：王小明">
      </div>
      <div class="field">
        <label>銷售通路</label>
        <select id="f-channel">
          <option value="online">線上</option>
          <option value="store">實體門市</option>
          <option value="partner">合作夥伴</option>
          <option value="other">其他</option>
        </select>
      </div>
      <div class="field s2">
        <label>級別（決定成本價）</label>
        <select id="f-level" onchange="onLevelChange()">
          <option value="0">一級輔導督導</option>
          <option value="1">皇家輔導督導</option>
        </select>
      </div>
      <div class="field">
        <label>手續費 / 運費</label>
        <input type="number" id="f-fee" placeholder="0" oninput="calcPreview()">
      </div>
      <div class="field" id="extra-income-wrap" style="display:none;">
        <label>額外收入（皇家專屬）</label>
        <input type="number" id="f-extra-income" placeholder="0" oninput="calcPreview()">
      </div>
      <div class="field">
        <label>備註（選填）</label>
        <input type="text" id="f-note" placeholder="備忘說明...">
      </div>
    </div>

    <!-- Product picker -->
    <div class="product-picker-wrap">
      <div class="picker-label" style="margin-bottom:8px;">選擇產品（可複選，點擊加入）</div>
      <div class="picker-header">
        <input class="picker-search" type="text" id="picker-search" placeholder="搜尋產品..." oninput="renderPicker()">
        <button class="btn-sm" onclick="clearSelectedProducts()">清除已選</button>
      </div>
      <div class="product-grid" id="product-grid"></div>
    </div>

    <!-- Selected items — qty only, single order total at bottom -->
    <div class="selected-items" id="selected-items-wrap" style="display:none;">
      <div class="selected-items-label">已選產品 — 調整數量</div>
      <div class="item-row-entry" style="background:transparent;padding:2px 10px;margin-bottom:2px;">
        <span class="ilabel" style="text-align:left;">產品</span>
        <span class="ilabel">數量</span>
        <span class="ilabel">單品成本</span>
        <span class="ilabel">小計成本</span>
        <span></span>
      </div>
      <div class="item-rows" id="item-rows"></div>

      <!-- Order total input -->
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;padding:12px 0 4px;">
        <div style="display:flex;flex-direction:column;gap:5px;">
          <label style="font-size:0.58rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);">加總成本（自動）</label>
          <input type="number" id="f-total-cost" readonly style="background:var(--surface2);border:1px solid transparent;border-radius:7px;color:var(--amber);font-family:var(--mono);font-size:0.9rem;padding:8px 10px;outline:none;font-weight:500;opacity:1;cursor:default;">
        </div>
        <div style="display:flex;flex-direction:column;gap:5px;">
          <label style="font-size:0.58rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);">訂單售出總金額</label>
          <input type="number" id="f-order-price" placeholder="填入收款金額" oninput="calcPreview()"
            style="background:var(--surface2);border:1px solid var(--accent);border-radius:7px;color:var(--text);font-family:var(--mono);font-size:0.9rem;padding:8px 10px;outline:none;transition:border-color 0.2s;">
        </div>
        <div style="display:flex;flex-direction:column;gap:5px;">
          <label style="font-size:0.58rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);">預估獲利（自動）</label>
          <input type="number" id="f-profit-preview" readonly style="background:var(--surface2);border:1px solid transparent;border-radius:7px;font-family:var(--mono);font-size:0.9rem;padding:8px 10px;outline:none;font-weight:500;opacity:1;cursor:default;">
        </div>
      </div>
    </div>

    <div class="form-footer">
      <div class="calc-preview" id="calc-preview">選擇產品後自動加總成本，再填入收款總金額計算獲利</div>
      <button class="btn-s" onclick="clearSalesForm()">清除</button>
      <button class="btn-p" onclick="addSalesRecord()">新增紀錄</button>
    </div>
  </div>

  <!-- Sales table -->
  <div class="card">
    <div class="card-header">
      <span class="card-title">銷售紀錄（<span id="table-month-label"></span>）</span>
