      <button class="btn-p" style="background:var(--red);color:#fff;" onclick="confirmDelete()">確認刪除</button>
    </div>
  </div>
</div>

<script>
// ══ Product catalogue ══
const PRODUCT_LIST = [
  {name:'纖纖飲',      costs:[790,700]},
  {name:'纖飄錠',      costs:[790,700]},
  {name:'爆纖錠',      costs:[470,430]},
  {name:'纖酵宿',      costs:[510,440]},
  {name:'紫纖飲',      costs:[510,440]},
  {name:'肽可可',      costs:[510,440]},
  {name:'肽奶茶',      costs:[510,440]},
  {name:'水光錠',      costs:[830,740]},
  {name:'水光面膜',    costs:[400,360]},
  {name:'婕肌零',      costs:[510,440]},
  {name:'玻尿酸',      costs:[510,440]},
  {name:'雪聚露',      costs:[690,620]},
  {name:'小白瓶',      costs:[690,620]},
  {name:'護手霜',      costs:[365,320]},
  {name:'洗髮精',      costs:[690,620]},
  {name:'養髮液',      costs:[570,500]},
  {name:'葉黃素飲',    costs:[570,500]},
  {name:'葉黃素果凍',  costs:[365,320]},
  {name:'益生菌',      costs:[690,620]},
  {name:'酒國',        costs:[365,320]},
  {name:'正冠茶',      costs:[510,440]},
  {name:'固樂纖',      costs:[830,740]},
  {name:'爆纖錠體驗包',costs:[133,120]},
  {name:'纖酵宿體驗包',costs:[89,75]},
  {name:'婕肌零體驗包',costs:[17,15]},
  {name:'洗髮精體驗包',costs:[24,12]},
];

const LEVEL_NAMES   = ['一級輔導督導','皇家輔導督導'];
const LEVEL_CLASSES = ['lv-2','lv-3'];
const CH_LABEL = {online:'線上',store:'實體門市',partner:'合作夥伴',other:'其他'};
const CH_CLASS  = {online:'ch-online',store:'ch-store',partner:'ch-partner',other:'ch-other'};

// ══ State ══
let salesRecords = JSON.parse(localStorage.getItem('sr-v4') || '[]');
let products     = JSON.parse(localStorage.getItem('prd-v4') || 'null');

if (!products) {
  products = PRODUCT_LIST.map((p,i) => ({
    id:i+1, name:p.name, sku:'', costs:p.costs, price:0, stock:0, sold:0
  }));
  localStorage.setItem('prd-v4', JSON.stringify(products));
}

// selectedItems: [{productId, qty, cost, price}]
let selectedItems = [];
let deleteCtx = null;

function save() {
  localStorage.setItem('sr-v4',  JSON.stringify(salesRecords));
  localStorage.setItem('prd-v4', JSON.stringify(products));
}

function fmt(n) {
  const abs = Math.abs(Math.round(n));
  return (n<0?'-':'')+'$'+abs.toLocaleString();
}
function todayStr()     { return new Date().toISOString().slice(0,10); }
function currentMonth() { const d=new Date(); return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0'); }
function monthDisplay(ym){ const [y,m]=ym.split('-'); return y+'年'+parseInt(m)+'月'; }

// ══ Tabs ══
function switchTab(name, el) {
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('panel-'+name).classList.add('active');
}

// ══ Month ══
function onMonthChange() {
  const ym = document.getElementById('view-month').value;
  document.getElementById('month-display').textContent = monthDisplay(ym);
  document.getElementById('table-month-label').textContent = monthDisplay(ym);
  renderSalesTable(); updateSalesMetrics();
}

// ══ Level change → update chip costs ══
function onLevelChange() {
  const lv = parseInt(document.getElementById('f-level').value);
  // Show extra income only for 皇家 (lv===1)
  const wrap = document.getElementById('extra-income-wrap');
  if (wrap) wrap.style.display = lv===1 ? '' : 'none';
  if (lv!==1) { const ei=document.getElementById('f-extra-income'); if(ei) ei.value=''; }
  // refresh cost for already-selected items
  selectedItems.forEach(item => {
    const p = products.find(x=>x.id===item.productId);
    if (p) item.cost = p.costs[lv];
  });
  renderPicker();
  renderSelectedItems();
  calcPreview();
}

// ══ Product picker ══
function renderPicker() {
  const lv  = parseInt(document.getElementById('f-level').value);
  const q   = document.getElementById('picker-search').value.toLowerCase();
  const grid = document.getElementById('product-grid');

  const filtered = products.filter(p => !q || p.name.includes(q));
  const selectedIds = new Set(selectedItems.map(i=>i.productId));

  grid.innerHTML = filtered.map(p => {
    const cost = p.costs[lv];
    const sel  = selectedIds.has(p.id);
    const skClass = p.stock<0?'neg':p.stock<=5?'low':'ok';
    const skLabel = p.stock<0?`庫存不足(${p.stock})`:p.stock<=5?`低庫存(${p.stock})`:`庫存:${p.stock}`;
    return `
      <div class="prod-chip${sel?' selected':''}" onclick="toggleProduct(${p.id})">
        <span class="chip-name">${p.name}</span>
        <span class="chip-cost">成本 ${fmt(cost)}</span>
        <span class="chip-stock ${skClass}">${skLabel}</span>
      </div>
    `;
  }).join('');
}

function toggleProduct(pid) {
  const lv  = parseInt(document.getElementById('f-level').value);
  const p   = products.find(x=>x.id===pid);
  if (!p) return;

  const idx = selectedItems.findIndex(i=>i.productId===pid);
  if (idx===-1) {
    selectedItems.push({ productId:pid, qty:1, cost:p.costs[lv], price:0 });
  } else {
    selectedItems.splice(idx, 1);
  }
  renderPicker();
  renderSelectedItems();
  calcPreview();
}

function clearSelectedProducts() {
  selectedItems = [];
  renderPicker();
  renderSelectedItems();
  calcPreview();
}

// ══ Selected items list ══
function renderSelectedItems() {
  const wrap = document.getElementById('selected-items-wrap');
  const rows = document.getElementById('item-rows');

  if (selectedItems.length === 0) {
    wrap.style.display = 'none';
    rows.innerHTML = '';
    return;
  }
  wrap.style.display = 'block';

  rows.innerHTML = selectedItems.map((item, i) => {
    const p = products.find(x=>x.id===item.productId);
    const name = p ? p.name : '—';
    const subCost = item.cost * item.qty;
    return `
      <div class="item-row-entry">
        <span class="iname" title="${name}">${name}</span>
        <input type="number" value="${item.qty}" min="1"
          oninput="updateItem(${i},'qty',this.value)"
          style="text-align:center;">
        <input type="number" value="${item.cost}" readonly>
        <input type="number" value="${Math.round(subCost)}" readonly
          style="color:var(--amber);">
        <button class="btn-icon" onclick="removeItem(${i})">✕</button>
      </div>
    `;
  }).join('');

  // update total cost field
  const totalCost = selectedItems.reduce((s,i)=>s+i.cost*i.qty, 0);
  const tcEl = document.getElementById('f-total-cost');
  if (tcEl) tcEl.value = Math.round(totalCost);
}

function updateItem(i, key, val) {
  selectedItems[i][key] = parseInt(val)||1;
  renderSelectedItems();
  calcPreview();
}

function removeItem(i) {
  selectedItems.splice(i, 1);
  renderPicker();
  renderSelectedItems();
  calcPreview();
}

// ══ Preview ══
function calcPreview() {
  const fee        = parseFloat(document.getElementById('f-fee').value)||0;
  const totalCost  = selectedItems.reduce((s,i)=>s+i.cost*i.qty, 0);
  const orderPrice   = parseFloat(document.getElementById('f-order-price')?document.getElementById('f-order-price').value:0)||0;
  const extraIncome = parseFloat(document.getElementById('f-extra-income')?document.getElementById('f-extra-income').value:0)||0;
  const profit      = orderPrice + extraIncome - totalCost - fee;
  const prev       = document.getElementById('calc-preview');

  // Update profit preview field
  const ppEl = document.getElementById('f-profit-preview');
  if (ppEl) {
    ppEl.value = selectedItems.length > 0 ? Math.round(profit) : '';
    ppEl.style.color = profit >= 0 ? 'var(--accent)' : 'var(--red)';
  }

  if (selectedItems.length === 0) {
    prev.className = 'calc-preview';
    prev.innerHTML = '選擇產品後自動加總成本，再填入收款總金額計算獲利';
    return;
  }

  if (orderPrice > 0) {
    const sign = profit>=0?'+':'';
    prev.className = 'calc-preview'+(profit<0?' neg':'');
    prev.innerHTML =
      '收款 '+fmt(orderPrice)+(extraIncome?' + 額外收入 '+fmt(extraIncome):'')+' − 成本 '+fmt(totalCost)+' − 手續費/運費 '+fmt(fee)+
      ' = 獲利 <strong>'+sign+fmt(profit)+'</strong>';
  } else {
    prev.className = 'calc-preview';
    prev.innerHTML =
      '加總成本：<strong style="color:var(--amber);">'+fmt(totalCost)+'</strong>'+
      '　（'+selectedItems.length+' 項）　請填入右側「訂單售出總金額」';
  }
}

// ══ Add sale ══
function addSalesRecord() {
  const custEl   = document.getElementById('f-customer');
  const customer = custEl.value.trim();
  if (!customer) {
    custEl.focus(); custEl.style.borderColor='var(--red)';
    setTimeout(()=>{custEl.style.borderColor='';},1200); return;
  }
  if (selectedItems.length === 0) {
    alert('請至少選擇一個產品'); return;
  }

  const lv  = parseInt(document.getElementById('f-level').value);
  const fee = parseFloat(document.getElementById('f-fee').value)||0;
  const extraIncome = parseFloat(document.getElementById('f-extra-income')?document.getElementById('f-extra-income').value:0)||0;
  const totalCost  = selectedItems.reduce((s,i)=>s+i.cost*i.qty,0);
  const totalPrice = parseFloat(document.getElementById('f-order-price').value)||0;
  const profit = totalPrice + extraIncome - totalCost - fee;

  const record = {
    id: Date.now(),
    date: document.getElementById('f-date').value || todayStr(),
    customer,
    level: lv,
    channel: document.getElementById('f-channel').value,
    items: selectedItems.map(i=>({...i})),
    fee, extraIncome, totalCost, totalPrice, profit,
    note: document.getElementById('f-note').value.trim()
  };

  salesRecords.unshift(record);

  // Update inventory
  selectedItems.forEach(item => {
    const idx = products.findIndex(p=>p.id===item.productId);
    if (idx!==-1) {
      products[idx].stock -= item.qty;
      products[idx].sold  += item.qty;
    }
  });

  save();
  clearSalesForm();
  renderSalesTable(); updateSalesMetrics();
  renderInvTable();   updateInvMetrics();
  renderPicker();
}

function clearSalesForm() {
  document.getElementById('f-date').value    = todayStr();
  document.getElementById('f-customer').value = '';
  document.getElementById('f-level').value   = '0';
  document.getElementById('f-channel').value = 'online';
  document.getElementById('f-fee').value     = '';
  document.getElementById('f-note').value    = '';
  document.getElementById('picker-search').value = '';
  const op = document.getElementById('f-order-price');
  if (op) op.value = '';
  const ei = document.getElementById('f-extra-income');
  if (ei) ei.value = '';
  const eiw = document.getElementById('extra-income-wrap');
  if (eiw) eiw.style.display='none';
  selectedItems = [];
  renderPicker(); renderSelectedItems(); calcPreview();
}

// ══ Sales table ══
function getViewMonth() { return document.getElementById('view-month').value; }

function renderSalesTable() {
  const ym = getViewMonth();
  const q  = document.getElementById('search').value.toLowerCase();
  const lv = document.getElementById('filter-level').value;
  const ch = document.getElementById('filter-channel').value;

  const filtered = salesRecords.map((r,i)=>({...r,_idx:i})).filter(r=>{
    const inMonth = r.date.slice(0,7)===ym;
    const prodNames = (r.items||[]).map(i=>{const p=products.find(x=>x.id===i.productId); return p?p.name:'';}).join(' ');
    const mq = !q||r.customer.toLowerCase().includes(q)||prodNames.toLowerCase().includes(q)||(r.note||'').toLowerCase().includes(q);
    const ml = lv===''||String(r.level)===lv;
    const mc = !ch||r.channel===ch;
    return inMonth&&mq&&ml&&mc;
  });

  const tbody = document.getElementById('sales-tbody');
  const empty = document.getElementById('sales-empty');
  if (filtered.length===0){tbody.innerHTML='';empty.style.display='block';return;}
  empty.style.display='none';

  // Cumulative within month
  const monthRecs = [...salesRecords].filter(r=>r.date.slice(0,7)===ym).reverse();
  const cumMap = {};
  let cum=0;
  monthRecs.forEach(r=>{cum+=r.profit;cumMap[r.id]=cum;});

  tbody.innerHTML = filtered.map(r=>{
    // build product tags
    const tags = (r.items||[]).map(i=>{
      const p=products.find(x=>x.id===i.productId);
      return `<span class="prod-tag">${p?p.name:'?'} ×${i.qty}</span>`;
    }).join('');
    return `
      <tr>
        <td class="m">${salesRecords.length-r._idx}</td>
        <td class="m">${r.date}</td>
        <td>${r.customer}</td>
        <td><span class="level-badge ${LEVEL_CLASSES[r.level]}">${LEVEL_NAMES[r.level]}</span></td>
        <td><div class="prod-tags">${tags||'—'}</div></td>
        <td><span class="badge ${CH_CLASS[r.channel]}">${CH_LABEL[r.channel]}</span></td>
        <td class="r m">${fmt(r.totalCost||0)}</td>
        <td class="r m">${fmt(r.totalPrice||0)}</td>
        <td class="r m">${r.extraIncome?fmt(r.extraIncome):'—'}</td>
        <td class="r m">${r.fee?fmt(r.fee):'—'}</td>
        <td class="r"><span class="${r.profit>=0?'vp':'vn'}">${fmt(r.profit)}</span></td>
        <td class="r"><span class="${(cumMap[r.id]||0)>=0?'vp':'vn'}">${fmt(cumMap[r.id]||0)}</span></td>
        <td class="m">${r.note||'—'}</td>
        <td><button class="btn-icon" onclick="askDelete('sales',${r._idx})">✕</button></td>
      </tr>
    `;
  }).join('');
}

function updateSalesMetrics() {
  const ym = getViewMonth();
  const mr = salesRecords.filter(r=>r.date.slice(0,7)===ym);
  const rev    = mr.reduce((s,r)=>s+(r.totalPrice||0),0);
  const extra  = mr.reduce((s,r)=>s+(r.extraIncome||0),0);
  const cost   = mr.reduce((s,r)=>s+(r.totalCost||0),0);
  const fee    = mr.reduce((s,r)=>s+(r.fee||0),0);
  const profit = mr.reduce((s,r)=>s+r.profit,0);
  document.getElementById('m-rev').textContent  = fmt(rev);
  document.getElementById('m-cost').textContent = fmt(cost);
  document.getElementById('m-fee').textContent  = fmt(fee);
  const mp=document.getElementById('m-profit');
  mp.textContent=fmt(profit); mp.className='metric-value'+(profit<0?' r':'');
  document.getElementById('m-count').textContent = mr.length;
}

// ══ Inventory ══
function addProduct() {
  const nameEl=document.getElementById('inv-name');
  const name=nameEl.value.trim();
  if(!name){nameEl.focus();nameEl.style.borderColor='var(--red)';setTimeout(()=>{nameEl.style.borderColor='';},1200);return;}
  products.push({
    id:Date.now(), name, sku:document.getElementById('inv-sku').value.trim(),
    costs:[
      parseFloat(document.getElementById('inv-c0').value)||0,
      parseFloat(document.getElementById('inv-c1').value)||0,
    ],
    price:parseFloat(document.getElementById('inv-price').value)||0,
    stock:parseInt(document.getElementById('inv-qty').value)||0,
    sold:0
  });
  save(); clearInvForm(); renderInvTable(); updateInvMetrics(); renderPicker();
}

function clearInvForm(){
  ['inv-name','inv-sku','inv-c0','inv-c1','inv-price','inv-qty'].forEach(id=>{document.getElementById(id).value='';});
}

function adjustStock(idx, sign, inputId) {
  const val=parseInt(document.getElementById(inputId).value)||0;
  if(!val) return;
  products[idx].stock+=sign*val;
  document.getElementById(inputId).value='';
  save(); renderInvTable(); updateInvMetrics(); renderPicker();
}

function renderInvTable(){
  const q=document.getElementById('inv-search').value.toLowerCase();
  const filtered=products.map((p,i)=>({...p,_idx:i})).filter(p=>!q||p.name.includes(q)||(p.sku||'').includes(q));
  const tbody=document.getElementById('inv-tbody');
  const empty=document.getElementById('inv-empty');
  if(!filtered.length){tbody.innerHTML='';empty.style.display='block';return;}
  empty.style.display='none';
  tbody.innerHTML=filtered.map(p=>{
    const sc=p.stock<0?'sk-neg':p.stock<=5?'sk-low':'sk-ok';
    return `<tr>
      <td><strong>${p.name}</strong></td>
      <td class="m">${p.sku||'—'}</td>
      <td class="r m">${fmt(p.costs[0])}</td><td class="r m">${fmt(p.costs[1]||0)}</td>
      <td class="r m">${p.price?fmt(p.price):'—'}</td>
      <td class="r"><span class="${sc}">${p.stock}</span></td>
      <td class="r"><span class="sk-ok">${p.sold}</span></td>
      <td><div class="inv-actions">
        <input class="adj-input" type="number" id="as-${p._idx}" placeholder="數量">
        <button class="btn-adj pl" onclick="adjustStock(${p._idx},1,'as-${p._idx}')">入庫</button>
        <button class="btn-adj mi" onclick="adjustStock(${p._idx},-1,'as-${p._idx}')">出庫</button>
      </div></td>
      <td><button class="btn-icon" onclick="askDelete('inv',${p._idx})">✕</button></td>
    </tr>`;
  }).join('');
}

function updateInvMetrics(){
  document.getElementById('inv-m-count').textContent=products.length;
  document.getElementById('inv-m-stock').textContent=products.reduce((s,p)=>s+p.stock,0);
  document.getElementById('inv-m-sold').textContent=products.reduce((s,p)=>s+p.sold,0);
  document.getElementById('inv-m-cost').textContent=fmt(products.reduce((s,p)=>s+p.stock*(p.costs[0]||0),0));
}

// ══ Delete ══
function askDelete(type,idx){
  deleteCtx={type,idx};
  document.getElementById('modal-del-msg').textContent=type==='sales'
    ?`確定要刪除第 ${salesRecords.length-idx} 筆銷售紀錄嗎？（庫存不會自動還原）`
    :`確定要刪除產品「${products[idx].name}」嗎？`;
  document.getElementById('modal-del').classList.add('open');
}
function confirmDelete(){
  if(!deleteCtx)return;
  if(deleteCtx.type==='sales'){salesRecords.splice(deleteCtx.idx,1);save();renderSalesTable();updateSalesMetrics();}
  else{products.splice(deleteCtx.idx,1);save();renderInvTable();updateInvMetrics();renderPicker();}
  closeModal();
}
function closeModal(){document.getElementById('modal-del').classList.remove('open');deleteCtx=null;}
document.getElementById('modal-del').addEventListener('click',e=>{if(e.target===document.getElementById('modal-del'))closeModal();});

// ══ Export ══
function downloadCSV(filename, rows) {
  const bom = '\uFEFF'; // UTF-8 BOM for Excel
  const csv = bom + rows.map(r =>
    r.map(cell => {
      const s = String(cell==null?'':cell);
      return s.includes(',') || s.includes('"') || s.includes('\n')
        ? '"' + s.replace(/"/g,'""') + '"'
        : s;
    }).join(',')
  ).join('\r\n');
  const blob = new Blob([csv], {type:'text/csv;charset=utf-8;'});
  const url  = URL.createObjectURL(blob);
  const a    = document.createElement('a');
  a.href = url; a.download = filename; a.click();
  setTimeout(()=>URL.revokeObjectURL(url), 1000);
}

function exportSalesCSV() {
  const header = ['#','日期','客人姓名/帳號','級別','產品（含數量）','銷售通路','加總成本','售出金額','手續費/運費','獲利','備註'];
  const rows = salesRecords.map((r, i) => {
    const prodStr = (r.items||[]).map(it=>{
      const p = products.find(x=>x.id===it.productId);
      return (p?p.name:'?')+'×'+it.qty;
    }).join(' / ');
    return [
      salesRecords.length - i,
      r.date,
      r.customer,
      LEVEL_NAMES[r.level],
      prodStr,
      CH_LABEL[r.channel],
      r.totalCost||0,
      r.totalPrice||0,
      r.extraIncome||0,
      r.fee||0,
      r.profit,
      r.note||''
    ];
  });
  downloadCSV('銷售紀錄_全部.csv', [header, ...rows]);
}

function exportMonthCSV() {
  const ym = document.getElementById('view-month').value;
  const [y,m] = ym.split('-');
  const monthRecs = salesRecords.filter(r=>r.date.slice(0,7)===ym);

  const header = ['#','日期','客人姓名/帳號','級別','產品（含數量）','銷售通路','加總成本','售出金額','額外收入','手續費/運費','獲利','月累計獲利','備註'];
  let cum = 0;
  const sorted = [...monthRecs].reverse();
  const cumMap = {};
  sorted.forEach(r=>{ cum+=r.profit; cumMap[r.id]=cum; });

  const rows = monthRecs.map((r,i)=>{
    const prodStr = (r.items||[]).map(it=>{
      const p = products.find(x=>x.id===it.productId);
      return (p?p.name:'?')+'×'+it.qty;
    }).join(' / ');
    return [
      monthRecs.length - i,
      r.date,
      r.customer,
      LEVEL_NAMES[r.level],
      prodStr,
      CH_LABEL[r.channel],
      r.totalCost||0,
      r.totalPrice||0,
      r.extraIncome||0,
      r.fee||0,
      r.profit,
      cumMap[r.id]||0,
      r.note||''
    ];
  });

  // Summary rows
  const totalRev    = monthRecs.reduce((s,r)=>s+(r.totalPrice||0),0);
  const totalCost   = monthRecs.reduce((s,r)=>s+(r.totalCost||0),0);
  const totalFee    = monthRecs.reduce((s,r)=>s+(r.fee||0),0);
  const totalProfit = monthRecs.reduce((s,r)=>s+r.profit,0);
  const summary = [
    ['','','','','','','','','','','',''],
    ['合計','','','','','',totalCost,totalRev,totalFee,totalProfit,'',''],
  ];

  downloadCSV(y+'年'+parseInt(m)+'月_銷售報表.csv', [header, ...rows, ...summary]);
}

function exportInvCSV() {
  const header = ['產品名稱','產品編號','實習成本','三級成本','三級輔導督導成本','二級輔導督導成本','建議售價','現有庫存','售出數量','庫存成本(實習)'];
  const rows = products.map(p=>[
    p.name, p.sku||'',
    p.costs[0], p.costs[1], p.costs[2], p.costs[3],
    p.price||0,
    p.stock, p.sold,
    p.stock * p.costs[0]
  ]);
  downloadCSV('產品庫存.csv', [header, ...rows]);
}

