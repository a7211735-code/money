      <table>
        <thead>
          <tr>
            <th>產品名稱</th><th>編號</th>
            <th class="r">一級成本</th><th class="r">皇家成本</th>
            <th class="r">建議售價</th>
            <th class="r">現有庫存</th><th class="r">售出數量</th>
